rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for admin privileges
    function isAdmin() {
      // Hardcoded admin UIDs for simplicity. 
      // In a production app, this might be a custom claim or a role in a separate document.
      let adminUIDs = ['UID_FOR_MICHAEL', 'UID_FOR_JANNI', 'UID_FOR_CHRISSY', 'UID_FOR_AMY'];
      return request.auth.uid in adminUIDs;
    }

    // Users can only be created if they have a @regallakeland.com email
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.token.email.matches('.*@regallakeland.com');
      allow update: if request.auth.uid == userId || isAdmin();
    }

    // Posts can be read by any authenticated user
    match /posts/{postId} {
      allow read: if request.auth != null;

      // Allow create only for authenticated users with verified @regallakeland.com emails
      allow create: if request.auth != null && request.auth.token.email_verified && request.auth.token.email.matches('.*@regallakeland.com');
      
      // Allow update only by the post author or an admin
      allow update: if request.resource.data.authorId == request.auth.uid || isAdmin();
      
      // Only admins can delete posts
      allow delete: if isAdmin();
    }

    // Comments can be read by any authenticated user
    match /posts/{postId}/comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.resource.data.authorId == request.auth.uid || isAdmin();
        allow delete: if isAdmin();
    }
  }
}
