rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function employee() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.matches('.*@regallakeland\\.com$')
        && request.auth.token.email_verified == true;
    }
    function admin() {
      return employee() && (
        request.auth.token.email == 'michael.h@regallakeland.com' ||
        request.auth.token.email == 'janni.r@regallakeland.com' ||
        request.auth.token.email == 'chrissy.h@regallakeland.com' ||
        request.auth.token.email == 'amy.m@regallakeland.com'
      );
    }
    match /profiles/{uid} {
      allow read: if employee();
      allow create: if employee() && request.auth.uid == uid;
      allow update: if (employee() && request.auth.uid == uid) || admin();
    }
    match /posts/{id} {
      allow read: if employee();
      allow create: if employee() && request.resource.data.uid == request.auth.uid && request.resource.data.email == request.auth.token.email;
      allow update, delete: if admin() || (employee() && request.auth.uid == resource.data.uid);
    }
    match /alerts/{id} {
      allow create: if employee();
      allow read, update, delete: if admin();
    }
  }
}
