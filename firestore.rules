rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function hasEmail() {
      return signedIn() && request.auth.token.email != null;
    }

    function employeeEmail() {
      return hasEmail()
        && request.auth.token.email.matches('.*@regallakeland\\.com$');
    }

    function hasProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid));
    }

    function requesterProfile() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }

    function emailApproved() {
      return signedIn()
        && (
          request.auth.token.email_verified == true
          || (hasProfile() && requesterProfile().manualVerified == true)
          || (hasProfile() && requesterProfile().accessApproved == true)
        );
    }

    function accessApproved() {
      return hasProfile()
        && requesterProfile().accessApproved == true
        && requesterProfile().banned != true;
    }

    function isCoreAdmin() {
      return hasEmail()
        && (
          request.auth.token.email == 'michael.h@regallakeland.com'
          || request.auth.token.email == 'janni.r@regallakeland.com'
        );
    }

    function isAdminUser() {
      return signedIn()
        && hasProfile()
        && (isCoreAdmin() || requesterProfile().isAdmin == true);
    }

    function marketplaceMember() {
      return signedIn()
        && employeeEmail()
        && hasProfile()
        && emailApproved()
        && accessApproved();
    }

    function ownProfile(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function protectedTarget() {
      return resource.data.email == 'michael.h@regallakeland.com'
        || resource.data.email == 'janni.r@regallakeland.com';
    }

    match /listings/{id} {
      allow read: if marketplaceMember();

      allow create: if marketplaceMember()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.userEmail == request.auth.token.email;

      allow update: if marketplaceMember()
        && (resource.data.uid == request.auth.uid || isAdminUser());

      allow delete: if marketplaceMember()
        && (resource.data.uid == request.auth.uid || isAdminUser());
    }

    match /profiles/{uid} {
      allow read: if (signedIn() && ownProfile(uid) && employeeEmail())
        || marketplaceMember()
        || isAdminUser();

      allow create: if signedIn() && ownProfile(uid) && employeeEmail();

      allow update: if signedIn()
        && employeeEmail()
        && (ownProfile(uid) || isAdminUser());

      allow delete: if isAdminUser()
        && (!protectedTarget() || request.auth.uid == uid);
    }
    match /eventResponses/{id} {
      allow read: if (signedIn() && employeeEmail() && hasProfile() && requesterProfile().banned != true)
        || isAdminUser();

      allow create, update: if ((signedIn() && employeeEmail() && hasProfile() && requesterProfile().banned != true)
        || isAdminUser())
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.userEmail == request.auth.token.email;

      allow delete: if ((signedIn() && employeeEmail() && hasProfile() && requesterProfile().banned != true)
        && resource.data.uid == request.auth.uid)
        || isAdminUser();
    }
  }
}
