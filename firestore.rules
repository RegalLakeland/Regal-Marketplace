rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is an admin
    function isAdmin(userId) {
      // IMPORTANT: Replace with your actual Admin User IDs (UIDs)
      let adminUids = ["YOUR_ADMIN_UID_HERE", "ANOTHER_ADMIN_UID_HERE"];
      return userId in adminUids;
    }

    // Only authenticated users from the specific domain can read or write posts.
    match /posts/{postId} {
      allow read: if request.auth != null && request.auth.token.email.matches('.*@regallakeland.com$');
      
      // Allow create if user is authenticated and from the correct domain
      allow create: if request.auth != null && request.auth.token.email.matches('.*@regallakeland.com$');
      
      // Allow update or delete only if the user is the author of the post OR if the user is an admin.
      allow update, delete: if request.auth != null && 
                              (request.auth.uid == resource.data.authorId || isAdmin(request.auth.uid));
    }

    // Rules for other collections would go here
  }
}