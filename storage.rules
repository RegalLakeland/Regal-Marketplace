
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow users to upload files to a `posts` folder, but only if they are authenticated.
    // The uploaded file must be smaller than 5MB and an image.
    match /posts/{fileName} {
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Allow anyone to read images.
    match /posts/{fileName} {
        allow read: if true;
    }
  }
}
