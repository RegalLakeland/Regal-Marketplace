rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /images/{userId}/{allPaths=**} {
      // Allow reads by anyone, as images are public content in posts
      allow read: if true;
      
      // Allow writes only if the user is authenticated and the path matches their UID
      // Also, enforce a size limit (e.g., 5MB)
      allow write: if request.auth != null && 
                    request.auth.uid == userId &&
                    request.resource.size < 5 * 1024 * 1024 &&
                    request.resource.contentType.matches('image/.*');
    }
  }
}